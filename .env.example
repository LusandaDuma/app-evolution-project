# Supabase — required for auth and database
# Create a project at https://supabase.com and copy values from Project Settings → API

# Client-side (embedded in the browser bundle at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-side (SSR, server functions — set in Vercel Environment Variables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: admin operations in trusted server code only (never expose to the client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
